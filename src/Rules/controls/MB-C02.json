{
  "control": "MB-C02",
  "title": "Admin & Auth Hardening",
  "rules": [
    {
      "id": "MB-R006",
      "title": "Non-default admin path (not /admin)",
      "control": "MB-C02",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_frontname_strong",
          "args": {
            "file": "app/etc/env.php",
            "path": "backend.frontName",
            "min_length": 8,
            "denylist": [
              "admin",
              "backend",
              "administrator",
              "adminpanel",
              "magento",
              "manage",
              "cms",
              "dashboard"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Admin path is non-default and not trivially guessable.",
        "fail": "Admin path is default, weak, or missing. Change env.php backend.frontName to a non-guessable value and update web server rules."
      }
    },
    {
      "id": "MB-R007",
      "title": "Admin 2FA module enabled",
      "control": "MB-C02",
      "severity": "critical",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_2fa_enabled",
          "args": {
            "file": "app/etc/config.php",
            "core_module": "Magento_TwoFactorAuth",
            "provider_modules": [
              "Magento_GoogleAuthenticator",
              "Magento_DuoSecurity",
              "Magento_U2fKey",
              "Magento_AdminAdobeImsTwoFactorAuth"
            ]
          }
        }
      ],
      "messages": {
        "pass": "Two-Factor Authentication core and at least one provider module are enabled for admin.",
        "fail": "Two-Factor Authentication is disabled, missing, or has no enabled provider module. Enable Magento_TwoFactorAuth and at least one admin 2FA provider."
      }
    },
    {
      "id": "MB-R008",
      "title": "Strong password policy enforced",
      "control": "MB-C02",
      "severity": "high",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_password_policy_strong",
          "args": {
            "file": "app/etc/config.php",
            "base_path": "system.default.admin.security",
            "min_password_length": 12,
            "max_lockout_failures": 10,
            "max_password_lifetime_days": 90
          }
        }
      ],
      "messages": {
        "pass": "Admin password/security policy meets minimum strength requirements.",
        "fail": "Admin password/security policy is weak or incomplete. Define minimum length, lockout, and rotation settings under admin/security."
      }
    },
    {
      "id": "MB-R009",
      "title": "Admin session timeout <= 900s",
      "control": "MB-C02",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_session_timeout",
          "args": {
            "file": "app/etc/config.php",
            "base_path": "system.default.admin.security",
            "max_seconds": 900
          }
        }
      ],
      "messages": {
        "pass": "Admin session lifetime is at or below 900 seconds.",
        "fail": "Admin session lifetime is missing or exceeds 900 seconds. Reduce admin/security/session_lifetime to ≤ 900 for better security."
      }
    },
    {
      "id": "MB-R010",
      "title": "Admin URL exposure restricted",
      "control": "MB-C02",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_exposure_restricted",
          "args": {
            "env_file": "app/etc/env.php",
            "paths": [
              "/admin/",
              "/index.php/admin/",
              "/backend/"
            ],
            "acl_files": [
              "nginx.conf",
              "pub/.htaccess",
              ".htaccess"
            ],
            "timeout_ms": 8000
          }
        }
      ],
      "messages": {
        "pass": "Admin URL is either non-default or network-restricted (deny/allow rules present).",
        "fail": "Admin URL is exposed (default path and no network ACLs). Change backend.frontName and/or restrict access via web server allow/deny."
      }
    },
    {
      "id": "MB-R011",
      "title": "Login rate-limiting / CAPTCHA enabled",
      "control": "MB-C02",
      "severity": "medium",
      "op": "all",
      "checks": [
        {
          "name": "magento_admin_captcha_or_rate_limit",
          "args": {
            "file": "app/etc/config.php",
            "max_lockout_failures": 10
          }
        }
      ],
      "messages": {
        "pass": "CAPTCHA, reCAPTCHA, or login lockout protection is enabled for admin authentication.",
        "fail": "CAPTCHA/rate-limiting protection is weak or missing. Enable admin CAPTCHA, reCAPTCHA, or login lockout controls."
      }
    }
  ]
}
